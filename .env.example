# Environment Variables for Portfolio
# Copy this file to .env.local for local development
# Add these same variables to Vercel Dashboard for production

# ===========================================
# REQUIRED VARIABLES - Must be set for app to work
# ===========================================

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
# For production: https://your-domain.vercel.app

NEXTAUTH_SECRET=your-secret-key-here
# Generate a random 32+ character string
# Use: https://generate-secret.vercel.app/32

# Admin Panel Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ===========================================
# OPTIONAL VARIABLES - For enhanced features
# ===========================================

# MongoDB Database (Optional - for persistent storage)
# Leave empty to use local storage fallback
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio

# Cloudinary (Optional - for image/file uploads)
# Leave empty to use local file storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# DEVELOPMENT NOTES
# ===========================================

# For Local Development:
# 1. Copy this file to .env.local
# 2. Update the values with your actual data
# 3. Run: npm run dev

# For Vercel Production:
# 1. Deploy to Vercel first
# 2. Get your Vercel domain (e.g., portfolio-xyz.vercel.app)
# 3. Update NEXTAUTH_URL with your domain
# 4. Add all variables to Vercel Dashboard
# 5. Redeploy to apply changes

# Security Notes:
# - Never commit .env.local to Git
# - Use strong, random secrets
# - Change default admin credentials
# - Use environment-specific values
